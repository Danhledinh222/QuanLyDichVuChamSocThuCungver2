@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - PetCare | Dịch vụ Spa & Cắt tỉa lông thú cưng cao cấp</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link rel="stylesheet" href="~/css/layout/site-layout.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <nav class="navbar navbar-expand-lg fixed-top" id="mainNav">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                <i class="fas fa-paw"></i> PetCare
            </a>

            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navContent">
                <i class="fas fa-bars fs-4 text-dark"></i>
            </button>
            <div class="collapse navbar-collapse" id="navContent">
                <ul class="navbar-nav ms-auto align-items-center gap-2">
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "Service")">Dịch vụ</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Pricing", "Home")">Bảng giá</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "Pet")">Thú cưng</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Contact", "Home")">Liên hệ</a></li>

                    <li class="nav-item ms-lg-3">
                        <a href="@Url.Action("Index", "Booking")" class="btn-booking-nav">Đặt lịch ngay</a>
                    </li>

                    @if (Context.Session.GetInt32("AccountId") != null)
                    {
                        var roleId = Context.Session.GetInt32("RoleId");
                        var name = Context.Session.GetString("CustomerName") ?? Context.Session.GetString("EmployeeName");

                        <li class="nav-item ms-lg-2 auth-area">
                            <div class="user-dropdown">
                                <button class="user-btn" id="userMenuBtn">
                                    <img src="~/images/common/user-avatar.jpg" alt="Avatar">
                                    <span class="user-name">@name</span>
                                    <i class="fas fa-chevron-down"></i>
                                </button>

                                <div class="dropdown-menu-custom" id="userDropdown">
                                    @if (roleId == 4)
                                    {
                                        <a href="@Url.Action("Index", "Profile")"><i class="far fa-user"></i> Hồ sơ của tôi</a>
                                        <a href="@Url.Action("Index", "Pet")"><i class="fas fa-paw"></i> Thú cưng</a>
                                        <a href="@Url.Action("Detail", "Booking")"><i class="far fa-calendar-check"></i> Lịch hẹn</a>
                                        <a href="@Url.Action("Billing", "Profile")"><i class="far fa-credit-card"></i> Thanh toán</a>
                                        <a href="@Url.Action("Reviews", "Profile")"><i class="far fa-star"></i> Đánh giá</a>
                                    }
                                    else
                                    {
                                        @if (roleId == 1)
                                        {
                                            <a href="@Url.Action("Index", "Admin")"><i class="fas fa-tachometer-alt"></i> Quản trị hệ thống</a>
                                        }
                                        <a href="@Url.Action("Index", "Home")"><i class="fas fa-house"></i> Trang chủ</a>
                                    }

                                    <div class="dropdown-divider"></div>
                                    <a href="@Url.Action("Logout", "Account")" class="text-danger"><i class="fas fa-sign-out-alt"></i> Đăng xuất</a>
                                </div>
                            </div>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item ms-lg-2">
                            <a href="@Url.Action("Login", "Account")" class="btn-outline-custom">Đăng nhập</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main role="main">
        @RenderBody()
    </main>

    <footer>
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-4 pe-lg-5">
                    <a href="@Url.Action("Index", "Home")" class="footer-brand"><i class="fas fa-paw"></i> PetCare</a>
                    <p class="opacity-75 mb-4 pe-4">Dịch vụ chăm sóc, spa và y tế cao cấp được thực hiện bằng tình yêu thương. Vì thú cưng của bạn xứng đáng với những điều tốt nhất.</p>
                    <div class="social-links">
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-tiktok"></i></a>
                    </div>
                </div>
                <div class="col-6 col-md-3 col-lg-2">
                    <h6 class="footer-title">Dịch vụ</h6>
                    <a href="@Url.Action("Index", "Service")" class="footer-link">Cắt tỉa lông cao cấp</a>
                    <a href="@Url.Action("Index", "Service")" class="footer-link">Kiểm tra sức khỏe</a>
                    <a href="@Url.Action("Index", "Service")" class="footer-link">Spa & Thư giãn</a>
                    <a href="@Url.Action("Index", "Service")" class="footer-link">Khách sạn thú cưng</a>
                    <a href="@Url.Action("Index", "Service")" class="footer-link">Huấn luyện cún con</a>
                    <a href="@Url.Action("Index", "Service")" class="footer-link">Chăm sóc răng miệng</a>
                </div>
                <div class="col-6 col-md-3 col-lg-2">
                    <h6 class="footer-title">Liên kết nhanh</h6>
                    <a href="@Url.Action("Index", "Home")" class="footer-link">Về chúng tôi</a>
                    <a href="@Url.Action("Contact", "Home")" class="footer-link">Đội ngũ</a>
                    <a href="@Url.Action("Pricing", "Home")" class="footer-link">Bảng giá</a>
                    <a href="@Url.Action("Contact", "Home")" class="footer-link">Liên hệ</a>
                    <a href="#" class="footer-link">Blog & Mẹo hay</a>
                    <a href="#" class="footer-link">Tuyển dụng</a>
                    <a href="#" class="footer-link">Chính sách bảo mật</a>
                </div>
                <div class="col-md-6 col-lg-4">
                    <h6 class="footer-title">Đăng ký nhận tin</h6>
                    <p class="opacity-75 mb-4">Nhận các mẹo chăm sóc thú cưng, ưu đãi đặc biệt và thông báo dịch vụ mới trực tiếp vào hộp thư của bạn.</p>
                    <div class="subscribe-form">
                        <form class="d-flex flex-column gap-3">
                            <input type="email" class="form-control py-3 px-4 rounded-pill" placeholder="your@email.com">
                            <button type="button" class="btn rounded-pill py-3 px-4 d-flex align-items-center justify-content-center gap-2">
                                Đăng ký <i class="fas fa-arrow-right"></i>
                            </button>
                        </form>
                        <small class="d-block mt-3 opacity-50"><i class="fas fa-lock me-1"></i> Không gửi thư rác. Hủy đăng ký bất cứ lúc nào.</small>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p class="mb-0 opacity-75">&copy; @DateTime.Now.Year PetCare & Spa. Đã đăng ký bản quyền. Tạo ra bằng <i class="fas fa-heart text-danger"></i> dành cho những người yêu thú cưng.</p>
                <div class="footer-bottom-links">
                    <a href="#">Điều khoản dịch vụ</a>
                    <a href="#">Chính sách bảo mật</a>
                    <a href="#">Chính sách Cookie</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        window.addEventListener('scroll', function() {
            const nav = document.getElementById('mainNav');
            if (window.scrollY > 50) nav.classList.add('scrolled');
            else nav.classList.remove('scrolled');
        });

        document.addEventListener('DOMContentLoaded', () => {
            const userBtn = document.getElementById('userMenuBtn');
            const dropdown = document.getElementById('userDropdown');
            if(userBtn && dropdown) {
                userBtn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    userBtn.classList.toggle('active');
                    dropdown.classList.toggle('active');
                });
                window.addEventListener('click', (e) => {
                    if (!dropdown.contains(e.target) && !userBtn.contains(e.target)) {
                        userBtn.classList.remove('active');
                        dropdown.classList.remove('active');
                    }
                });
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
