    <!-- MAIN CONTENT -->
    <main class="main-content">
        <div class="container" style="max-width: 900px;">
            
            <!-- Page Header -->
            <div class="page-header">
                <h1 class="page-title">Lịch sử đặt lịch</h1>
                <p class="page-subtitle">Xem lại và quản lý các lịch hẹn chăm sóc thú cưng của bạn.</p>
            </div>

            <!-- NEW: 1. BOOKING STATS -->
            <div class="stats-overview">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-calendar-alt"></i></div>
                    <div class="stat-data">
                        <span class="stat-number">12</span>
                        <span class="stat-label">Tổng lịch đặt</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon green"><i class="fas fa-check-circle"></i></div>
                    <div class="stat-data">
                        <span class="stat-number">8</span>
                        <span class="stat-label">Đã hoàn thành</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon yellow"><i class="fas fa-clock"></i></div>
                    <div class="stat-data">
                        <span class="stat-number">3</span>
                        <span class="stat-label">Lịch sắp tới</span>
                    </div>
                </div>
            </div>

            <!-- Filters -->
            <div class="filter-container">
                <div class="filter-group">
                    <label>Trạng thái:</label>
                    <select class="form-select w-auto flex-grow-1">
                        <option value="all">Tất cả trạng thái</option>
                        <option value="pending">Chờ xác nhận</option>
                        <option value="completed">Đã hoàn thành</option>
                        <option value="cancelled">Đã hủy</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label>Từ ngày:</label>
                    <input type="date" class="form-control w-auto flex-grow-1">
