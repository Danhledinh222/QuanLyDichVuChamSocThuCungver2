<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lịch sử đặt lịch | PetCare</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@@400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* =========================================
           1. CORE VARIABLES & BASE
        ========================================= */
        :root {
            --bg-color: #FAFAF7;
            --primary-green: #10B981;
            --primary-green-hover: #059669;
            --dark-charcoal: #111827;
            --text-muted: #6B7280;
            --card-bg: #FFFFFF;
            --soft-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
            --hover-shadow: 0 15px 35px rgba(16, 185, 129, 0.08);
            --radius-xl: 32px;
            --radius-lg: 20px;
            --radius-md: 12px;
            --border-light: #F3F4F6;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-color);
            color: var(--dark-charcoal);
            margin: 0;
            padding-top: 100px;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .main-content { flex: 1; padding: 40px 0 80px 0; }
        
        a { text-decoration: none; }

        /* =========================================
           2. HEADER (Giữ nguyên)
        ========================================= */
        .navbar { padding: 20px 0; transition: all 0.4s ease; z-index: 1000; background: var(--bg-color); }
        .navbar.scrolled { background: rgba(250, 250, 247, 0.95); backdrop-filter: blur(10px); padding: 15px 0; box-shadow: 0 4px 30px rgba(0,0,0,0.05); }
        .navbar-brand { font-weight: 800; font-size: 1.5rem; color: var(--dark-charcoal); }
        .navbar-brand i { color: var(--primary-green); margin-right: 8px; }
        .nav-link { font-weight: 500; color: var(--text-muted); margin: 0 15px; font-size: 1rem; transition: color 0.3s; }
        .nav-link:hover { color: var(--dark-charcoal); font-weight: 600; }
        
        /* User Dropdown */
        .user-dropdown { position: relative; }
        .user-btn { background: white; border: 1px solid var(--border-light); border-radius: 50px; padding: 6px 16px 6px 6px; display: flex; align-items: center; gap: 10px; cursor: pointer; transition: all 0.3s ease; }
        .user-btn:hover, .user-btn.active { border-color: var(--primary-green); box-shadow: 0 4px 15px rgba(16, 185, 129, 0.1); }
        .user-btn img { width: 36px; height: 36px; border-radius: 50%; object-fit: cover; }
        .user-name { font-weight: 600; color: var(--dark-charcoal); font-size: 0.95rem; }
        .user-btn i { color: var(--text-muted); font-size: 0.8rem; transition: transform 0.3s; }
        .user-btn.active i { transform: rotate(180deg); }

        .dropdown-menu-custom {
            position: absolute; top: calc(100% + 12px); right: 0; width: 240px; background: var(--card-bg); border-radius: var(--radius-md); box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08); border: 1px solid var(--border-light); padding: 12px;
            opacity: 0; visibility: hidden; transform: translateY(15px); transition: all 0.3s ease; z-index: 1000;
        }
        .dropdown-menu-custom.active { opacity: 1; visibility: visible; transform: translateY(0); }
        .dropdown-menu-custom a { display: flex; align-items: center; gap: 12px; padding: 12px 16px; color: var(--dark-charcoal); font-weight: 500; font-size: 0.95rem; border-radius: 12px; transition: 0.2s; }
        .dropdown-menu-custom a i { width: 20px; color: var(--text-muted); font-size: 1.1rem; text-align: center; }
        .dropdown-menu-custom a:hover { background-color: #F9FAFB; color: var(--primary-green); }
        .dropdown-menu-custom a:hover i { color: var(--primary-green); }
        .dropdown-divider { height: 1px; background-color: var(--border-light); margin: 8px 0; }

        /* =========================================
           3. BOOKING HISTORY PAGE & NEW SECTIONS
        ========================================= */
        .page-header { margin-bottom: 30px; }
        .page-title { font-weight: 800; font-size: 2rem; color: var(--dark-charcoal); margin-bottom: 10px; }
        .page-subtitle { color: var(--text-muted); font-size: 1rem; }

        /* --- NEW: 1. BOOKING STATS --- */
        .stats-overview {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .stat-card {
            background: var(--card-bg);
            border-radius: 16px;
            border: 1px solid var(--border-light);
            box-shadow: var(--soft-shadow);
            padding: 20px;
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .stat-icon {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            background: rgba(16, 185, 129, 0.1);
            color: var(--primary-green);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
        }
        
        .stat-icon.green { background: #D1FAE5; color: #059669; }
        .stat-icon.yellow { background: #FEF3C7; color: #D97706; }
        
        .stat-data { display: flex; flex-direction: column; }
        .stat-number { font-size: 1.6rem; font-weight: 800; color: var(--dark-charcoal); line-height: 1.2;}
        .stat-label { font-size: 0.85rem; color: var(--text-muted); font-weight: 600;}

        /* --- Filters (Giữ nguyên) --- */
        .filter-container {
            background: var(--card-bg);
            padding: 20px;
            border-radius: var(--radius-md);
            box-shadow: var(--soft-shadow);
            border: 1px solid var(--border-light);
            margin-bottom: 30px;
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            align-items: center;
        }
        .filter-group { display: flex; align-items: center; gap: 10px; flex-grow: 1; min-width: 200px;}
        .filter-group label { font-weight: 600; font-size: 0.9rem; color: var(--text-muted); white-space: nowrap;}
        .form-select, .form-control { border-radius: 10px; border: 1px solid #E5E7EB; padding: 10px 15px; font-size: 0.95rem; background-color: #F9FAFB; cursor: pointer; transition: 0.3s;}
        .form-select:focus, .form-control:focus { border-color: var(--primary-green); box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1); background: white;}

        /* --- Booking List & Cards (Giữ nguyên) --- */
        .booking-list { display: flex; flex-direction: column; gap: 20px; }

        .booking-card {
            background: var(--card-bg);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border-light);
            box-shadow: var(--soft-shadow);
            transition: all 0.3s ease;
            overflow: hidden;
        }
        .booking-card:hover { box-shadow: var(--hover-shadow); transform: translateY(-3px); border-color: rgba(16, 185, 129, 0.2); }

        .bc-header { padding: 25px; display: flex; align-items: center; gap: 20px; cursor: pointer; user-select: none; }
        .bc-date-box { background: rgba(16, 185, 129, 0.1); color: var(--primary-green); min-width: 70px; height: 70px; border-radius: 14px; display: flex; flex-direction: column; align-items: center; justify-content: center; }
        .bc-date-box .day { font-size: 1.6rem; font-weight: 800; line-height: 1; }
        .bc-date-box .month { font-size: 0.85rem; font-weight: 600; text-transform: uppercase; }

        .bc-info { flex-grow: 1; }
        .bc-info .booking-id { font-size: 0.9rem; color: var(--text-muted); font-weight: 600; margin-bottom: 5px; }
        .bc-info h4 { font-size: 1.2rem; font-weight: 800; margin-bottom: 8px; color: var(--dark-charcoal); }
        .bc-info .services { font-size: 0.95rem; color: var(--text-muted); margin: 0; display: flex; align-items: center; gap: 8px;}

        .bc-meta { text-align: right; min-width: 150px; }
        .bc-price { font-size: 1.3rem; font-weight: 800; color: var(--primary-green); margin-bottom: 8px; }
        
        .status-badge { padding: 6px 14px; border-radius: 50px; font-size: 0.8rem; font-weight: 700; display: inline-block;}
        .status-completed { background: rgba(16, 185, 129, 0.1); color: var(--primary-green); }
        .status-pending { background: #FEF3C7; color: #D97706; }
        .status-cancelled { background: #FEE2E2; color: #EF4444; }

        .bc-toggle { width: 40px; display: flex; justify-content: flex-end; color: var(--text-muted); transition: 0.3s; font-size: 1.2rem;}
        
        .bc-body { max-height: 0; opacity: 0; overflow: hidden; transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); background: #FAFAFA; border-top: 1px solid transparent; }
        .bc-content { padding: 25px; }

        .booking-card.expanded .bc-body { max-height: 500px; opacity: 1; border-top-color: var(--border-light); }
        .booking-card.expanded .bc-toggle { transform: rotate(180deg); color: var(--primary-green); }
        .booking-card.expanded .bc-header { background: #FFFFFF; }

        .detail-row { display: flex; justify-content: space-between; margin-bottom: 15px; font-size: 0.95rem; }
        .detail-row .label { color: var(--text-muted); font-weight: 500; }
        .detail-row .value { font-weight: 600; color: var(--dark-charcoal); text-align: right; }
        .note-box { background: white; padding: 15px; border-radius: 10px; border: 1px solid var(--border-light); font-size: 0.9rem; color: var(--text-muted); margin-top: 20px;}

        .bc-actions { display: flex; justify-content: flex-end; gap: 12px; margin-top: 25px; padding-top: 20px; border-top: 1px dashed var(--border-light); }
        .btn-action { padding: 8px 20px; border-radius: 50px; font-weight: 600; font-size: 0.9rem; cursor: pointer; transition: 0.3s; border: 1px solid transparent; background: transparent; display: inline-flex; align-items: center; text-decoration: none;}
        .btn-action i { margin-right: 6px; }
        .btn-primary-action { background: var(--primary-green); color: white; }
        .btn-primary-action:hover { background: var(--primary-green-hover); box-shadow: 0 4px 12px rgba(16,185,129,0.2); color: white;}
        .btn-outline-action { border-color: var(--border-light); color: var(--dark-charcoal); background: white; }
        .btn-outline-action:hover { border-color: var(--dark-charcoal); color: var(--dark-charcoal);}
        .btn-danger-action { color: #EF4444; background: rgba(239, 68, 68, 0.1); }
        .btn-danger-action:hover { background: #EF4444; color: white; }

        /* --- Empty State --- */
        .empty-state { display: none; text-align: center; padding: 60px 20px; background: var(--card-bg); border-radius: var(--radius-lg); border: 1px dashed #D1D5DB; }
        .empty-state img { width: 150px; opacity: 0.5; margin-bottom: 20px; }
        .empty-state h4 { font-weight: 800; color: var(--dark-charcoal); margin-bottom: 10px; }
        .empty-state p { color: var(--text-muted); margin-bottom: 25px; }

        /* --- NEW: 2. QUICK ACTION SECTION --- */
        .quick-action-cta {
            background: linear-gradient(135deg, #ECFDF5 0%, #FFFFFF 100%);
            border: 1px solid #D1FAE5;
            border-radius: 20px;
            padding: 35px 40px;
            margin-top: 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: var(--soft-shadow);
        }
        
        .cta-content { max-width: 500px; }
        .cta-content h3 { font-size: 1.5rem; font-weight: 800; color: var(--dark-charcoal); margin-bottom: 10px; }
        .cta-content p { color: var(--text-muted); margin-bottom: 20px; font-size: 0.95rem; line-height: 1.6;}
        
        .cta-buttons { display: flex; gap: 15px; }
        
        .cta-visual {
            width: 100px;
            height: 100px;
            background: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            color: var(--primary-green);
            box-shadow: var(--soft-shadow);
        }

        /* --- Responsive --- */
        @@media (max-width: 768px) {
            .stats-overview { grid-template-columns: 1fr; }
            .bc-header { flex-wrap: wrap; position: relative; padding: 20px; }
            .bc-date-box { width: 60px; height: 60px; }
            .bc-info { width: calc(100% - 90px); }
            .bc-meta { width: 100%; text-align: left; display: flex; justify-content: space-between; align-items: center; margin-top: 10px; }
            .bc-price { margin-bottom: 0; }
            .bc-toggle { position: absolute; top: 35px; right: 20px; }
            .filter-container { flex-direction: column; align-items: stretch; }
            .bc-actions { flex-direction: column; }
            .btn-action { width: 100%; justify-content: center; }
            .quick-action-cta { flex-direction: column; text-align: center; padding: 30px 20px; }
            .cta-content { margin-bottom: 25px; }
            .cta-buttons { justify-content: center; flex-wrap: wrap; }
            .cta-visual { display: none; }
        }

        /* =========================================
           4. FOOTER (Giữ nguyên)
        ========================================= */
        footer { background: #064E3B; color: #D1FAE5; padding: 80px 0 30px; }
        .footer-brand { color: white; font-size: 1.5rem; font-weight: 800; text-decoration: none; display: inline-block; margin-bottom: 20px; }
        .footer-brand i { color: var(--primary-green); }
        .social-links a { display: inline-flex; align-items: center; justify-content: center; width: 36px; height: 36px; background: rgba(255,255,255,0.1); color: white; border-radius: 50%; margin-right: 10px; transition: 0.3s; }
        .social-links a:hover { background: var(--primary-green); transform: translateY(-3px); }
        .footer-title { color: white; font-weight: 700; margin-bottom: 20px; font-size: 1.1rem; }
        .footer-link { color: #D1FAE5; display: block; margin-bottom: 12px; font-size: 0.95rem; transition: 0.3s; text-decoration: none;}
        .footer-link:hover { color: white; }
        .subscribe-form .form-control { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); color: white; }
        .subscribe-form .form-control::placeholder { color: #A7F3D0; }
        .subscribe-form .btn { background: var(--primary-green); color: white; font-weight: 600; }
        .subscribe-form .btn:hover { background: var(--primary-green-hover); }
        .footer-bottom { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 30px; margin-top: 50px; display: flex; justify-content: space-between; align-items: center; font-size: 0.85rem; }
        .footer-bottom-links a { color: #D1FAE5; margin-left: 20px; transition: 0.3s; text-decoration: none;}
        .footer-bottom-links a:hover { color: white; }
        @@media (max-width: 991px) { .footer-bottom { flex-direction: column; gap: 15px; } }
        /* --- THIẾT KẾ NAVBAR CHUẨN NHƯ ẢNH --- */
.navbar {
    padding: 12px 0; /* Thu gọn padding để thanh nav thanh thoát hơn */
    transition: all 0.4s ease;
    z-index: 1000;
    background: #ffffff;
    box-shadow: 0 1px 10px rgba(0, 0, 0, 0.05); /* Đổ bóng nhẹ dưới viền */
}
.navbar-brand {
    font-weight: 800;
    font-size: 1.5rem;
    color: #111827;
}
.navbar-brand i {
    color: #10B981; /* Nút chân chó màu xanh */
    margin-right: 8px;
}

/* Các link điều hướng */
.nav-link {
    font-weight: 600;
    color: #6B7280; /* Màu xám nhạt như ảnh */
    margin: 0 10px;
    font-size: 0.95rem;
    transition: color 0.3s;
}
.nav-link:hover, .nav-link.active {
    color: #111827; /* Đen đậm khi hover */
}

/* Nút Đặt lịch ngay */
.btn-booking-nav {
    background-color: #10B981;
    color: white;
    border: none;
    padding: 10px 24px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    text-decoration: none;
}
.btn-booking-nav:hover {
    background-color: #059669;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(16, 185, 129, 0.2);
}

/* User Pill (Khung chứa Avatar và Tên Danh) */
.user-dropdown { position: relative; }
.user-btn {
    background: white;
    border: 1px solid #E5E7EB;
    border-radius: 50px;
    padding: 6px 16px 6px 6px;
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    transition: all 0.3s ease;
}
.user-btn:hover, .user-btn.active {
    border-color: #10B981;
    box-shadow: 0 4px 15px rgba(16, 185, 129, 0.1);
}
.user-btn img {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
}
.user-name {
    font-weight: 600;
    color: #111827;
    font-size: 0.95rem;
}
.user-btn i {
    color: #6B7280;
    font-size: 0.75rem;
    transition: transform 0.3s ease;
}
.user-btn.active i { transform: rotate(180deg); }

/* Menu thả xuống của User */
.dropdown-menu-custom {
    position: absolute; top: calc(100% + 12px); right: 0; width: 240px; background: #FFFFFF; border-radius: 16px; box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08); border: 1px solid #E5E7EB; padding: 12px; opacity: 0; visibility: hidden; transform: translateY(15px); transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); z-index: 1000; display: flex; flex-direction: column;
}
.dropdown-menu-custom.active { opacity: 1; visibility: visible; transform: translateY(0); }
.dropdown-menu-custom a { display: flex; align-items: center; gap: 12px; padding: 12px 16px; color: #111827; text-decoration: none; font-weight: 500; font-size: 0.95rem; border-radius: 12px; transition: all 0.2s ease; }
.dropdown-menu-custom a i { width: 20px; color: #6B7280; font-size: 1.1rem; text-align: center; transition: color 0.2s ease; }
.dropdown-menu-custom a:hover { background-color: #F9FAFB; color: #10B981; }
.dropdown-menu-custom a:hover i { color: #10B981; }
.dropdown-divider { height: 1px; background-color: #E5E7EB; margin: 8px 0; }
    </style>
</head>
