@{
    Layout = null; // Trang độc lập không dùng Header/Footer chung
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quên mật khẩu | PetCare</title>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link rel="stylesheet" href="~/css/pages/account/forgotpassword.css" asp-append-version="true" />
</head>
<body>

    <div class="forgot-wrapper">
        <div class="forgot-left">
            <div class="left-text">
                <h2>Khôi phục mật khẩu</h2>
                <p>Đừng quá lo lắng, đôi khi chúng ta cũng có thể quên mất vài thứ. Chúng tôi sẽ giúp bạn lấy lại quyền truy cập ngay thôi.</p>
            </div>
            <div class="left-image"></div>
        </div>

        <div class="forgot-right">
            <div class="form-header">
                <h3>Quên mật khẩu?</h3>
                <p>Vui lòng nhập địa chỉ email bạn đã sử dụng để đăng ký. Chúng tôi sẽ gửi một liên kết để thiết lập lại mật khẩu của bạn.</p>
            </div>

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert-error">
                    <i class="fas fa-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
                </div>
            }

            <form asp-action="ForgotPassword" asp-controller="Account" method="POST">
                <div class="input-group">
                    <label for="email">Địa chỉ Email</label>
                    <input type="email" name="email" id="email" placeholder="Nhập địa chỉ email của bạn" required>
                </div>

                <button type="submit" class="btn-submit">
                    Gửi liên kết khôi phục <i class="fas fa-paper-plane"></i>
                </button>
            </form>

            <div class="form-footer">
                <a href="@Url.Action("Login", "Account")"><i class="fas fa-arrow-left"></i> Quay lại Đăng nhập</a>
            </div>
        </div>
    </div>

</body>
</html>