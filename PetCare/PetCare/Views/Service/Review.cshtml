<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đánh giá dịch vụ | PetCare</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@@400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* =========================================
           1. CORE VARIABLES & BASE
        ========================================= */
        :root {
            --bg-color: #FAFAF7;
            --primary-green: #10B981;
            --primary-green-hover: #059669;
            --dark-charcoal: #111827;
            --text-muted: #6B7280;
            --card-bg: #FFFFFF;
            --soft-shadow: 0 10px 40px rgba(0, 0, 0, 0.05);
            --radius-xl: 32px;
            --radius-lg: 24px;
            --radius-md: 16px;
            --border-light: #F3F4F6;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-color);
            color: var(--dark-charcoal);
            margin: 0;
            padding-top: 100px;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .main-content { flex: 1; padding: 60px 0 100px 0; }
        a { text-decoration: none; }

        /* =========================================
           2. HEADER & FOOTER (Giữ nguyên)
        ========================================= */
        .navbar { padding: 20px 0; transition: all 0.4s ease; z-index: 1000; background: var(--bg-color); }
        .navbar.scrolled { background: rgba(250, 250, 247, 0.95); backdrop-filter: blur(10px); padding: 15px 0; box-shadow: 0 4px 30px rgba(0,0,0,0.05); }
        .navbar-brand { font-weight: 800; font-size: 1.5rem; color: var(--dark-charcoal); }
        .navbar-brand i { color: var(--primary-green); margin-right: 8px; }
        .nav-link { font-weight: 500; color: var(--text-muted); margin: 0 15px; font-size: 1rem; transition: color 0.3s; }
        .nav-link:hover { color: var(--dark-charcoal); font-weight: 600; }
        
        .user-dropdown { position: relative; }
        .user-btn { background: white; border: 1px solid var(--border-light); border-radius: 50px; padding: 6px 16px 6px 6px; display: flex; align-items: center; gap: 10px; cursor: pointer; transition: all 0.3s ease; }
        .user-btn:hover, .user-btn.active { border-color: var(--primary-green); box-shadow: 0 4px 15px rgba(16, 185, 129, 0.1); }
        .user-btn img { width: 36px; height: 36px; border-radius: 50%; object-fit: cover; }
        .user-name { font-weight: 600; color: var(--dark-charcoal); font-size: 0.95rem; }
        .user-btn i { color: var(--text-muted); font-size: 0.8rem; transition: transform 0.3s; }
        .user-btn.active i { transform: rotate(180deg); }

        .dropdown-menu-custom {
            position: absolute; top: calc(100% + 12px); right: 0; width: 240px; background: var(--card-bg); border-radius: var(--radius-md); box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08); border: 1px solid var(--border-light); padding: 12px;
            opacity: 0; visibility: hidden; transform: translateY(15px); transition: all 0.3s ease; z-index: 1000;
        }
        .dropdown-menu-custom.active { opacity: 1; visibility: visible; transform: translateY(0); }
        .dropdown-menu-custom a { display: flex; align-items: center; gap: 12px; padding: 12px 16px; color: var(--dark-charcoal); font-weight: 500; font-size: 0.95rem; border-radius: 12px; transition: 0.2s; }
        .dropdown-menu-custom a i { width: 20px; color: var(--text-muted); font-size: 1.1rem; text-align: center; }
        .dropdown-menu-custom a:hover { background-color: #F9FAFB; color: var(--primary-green); }
        .dropdown-menu-custom a:hover i { color: var(--primary-green); }
        .dropdown-divider { height: 1px; background-color: var(--border-light); margin: 8px 0; }

        footer { background: #064E3B; color: #D1FAE5; padding: 80px 0 30px; }
        .footer-brand { color: white; font-size: 1.5rem; font-weight: 800; text-decoration: none; display: inline-block; margin-bottom: 20px; }
        .footer-brand i { color: var(--primary-green); }
        .social-links a { display: inline-flex; align-items: center; justify-content: center; width: 36px; height: 36px; background: rgba(255,255,255,0.1); color: white; border-radius: 50%; margin-right: 10px; transition: 0.3s; }
        .social-links a:hover { background: var(--primary-green); transform: translateY(-3px); }
        .footer-title { color: white; font-weight: 700; margin-bottom: 20px; font-size: 1.1rem; }
        .footer-link { color: #D1FAE5; display: block; margin-bottom: 12px; font-size: 0.95rem; transition: 0.3s; text-decoration: none;}
        .footer-link:hover { color: white; }
        .subscribe-form .form-control { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); color: white; }
        .subscribe-form .form-control::placeholder { color: #A7F3D0; }
        .subscribe-form .btn { background: var(--primary-green); color: white; font-weight: 600; }
        .subscribe-form .btn:hover { background: var(--primary-green-hover); }
        .footer-bottom { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 30px; margin-top: 50px; display: flex; justify-content: space-between; align-items: center; font-size: 0.85rem; }
        .footer-bottom-links a { color: #D1FAE5; margin-left: 20px; transition: 0.3s; text-decoration: none;}
        .footer-bottom-links a:hover { color: white; }

        /* =========================================
           3. REVIEW PAGE STYLES
        ========================================= */
        .review-wrapper {
            max-width: 650px;
            margin: 0 auto;
        }

        .review-header {
            text-align: center;
            margin-bottom: 30px;
        }
        .review-header h2 { font-weight: 800; font-size: 2rem; color: var(--dark-charcoal); margin-bottom: 10px; }
        .review-header p { color: var(--text-muted); font-size: 1.05rem; }

        .review-card {
            background: var(--card-bg);
            border-radius: var(--radius-lg);
            padding: 40px;
            box-shadow: var(--soft-shadow);
            border: 1px solid var(--border-light);
        }

        /* --- 1. Service Summary --- */
        .service-summary {
            background: #F9FAFB;
            border-radius: var(--radius-md);
            padding: 20px;
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 35px;
            border: 1px solid var(--border-light);
        }
        .ss-avatar {
            width: 60px; height: 60px; border-radius: 14px;
            object-fit: cover;
        }
        .ss-info h4 { font-weight: 800; font-size: 1.1rem; margin-bottom: 4px; color: var(--dark-charcoal); }
        .ss-info p { margin: 0; color: var(--text-muted); font-size: 0.9rem; }
        .ss-info p strong { color: var(--dark-charcoal); font-weight: 600; }

        /* --- 2. Rating Section --- */
        .rating-section {
            text-align: center;
            margin-bottom: 35px;
        }
        .rating-section h5 { font-weight: 700; font-size: 1.1rem; margin-bottom: 15px; }
        
        .stars-container {
            display: flex;
            justify-content: center;
            gap: 12px;
            font-size: 2.5rem;
            color: #D1D5DB;
            cursor: pointer;
            user-select: none;
        }
        .stars-container i { transition: transform 0.2s, color 0.2s; }
        .stars-container i.hover { color: #FCD34D; transform: scale(1.1); }
        .stars-container i.active { color: #F59E0B; font-weight: 900; }

        /* --- 3. Review Form (Tags + Textarea) --- */
        .form-label { font-weight: 700; font-size: 1rem; color: var(--dark-charcoal); margin-bottom: 12px; display: block; }
        
        .tags-container {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 20px;
        }
        .review-tag {
            padding: 8px 18px;
            border-radius: 50px;
            border: 1px solid #D1D5DB;
            background: transparent;
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .review-tag:hover { border-color: var(--primary-green); color: var(--primary-green); background: rgba(16, 185, 129, 0.05); }
        .review-tag.active { background: rgba(16, 185, 129, 0.1); color: var(--primary-green); border-color: var(--primary-green); }

        .form-control-custom {
            width: 100%;
            padding: 16px;
            border-radius: var(--radius-md);
            border: 1px solid #E5E7EB;
            background-color: #F9FAFB;
            font-family: inherit;
            font-size: 0.95rem;
            resize: vertical;
            min-height: 120px;
            transition: all 0.3s ease;
            margin-bottom: 30px;
        }
        .form-control-custom:focus { outline: none; background-color: #FFFFFF; border-color: var(--primary-green); box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1); }

        /* --- 4. Store Reply Preview --- */
        .reply-preview {
            background: #ECFDF5;
            padding: 20px;
            border-radius: var(--radius-md);
            border-left: 4px solid var(--primary-green);
            margin-bottom: 30px;
            display: none; /* Hiển thị qua JS khi nhập review */
            animation: fadeIn 0.4s ease;
        }
        .reply-preview h6 { font-weight: 800; color: var(--primary-green-hover); margin-bottom: 8px; font-size: 0.95rem; display: flex; align-items: center; gap: 8px; }
        .reply-preview p { margin: 0; color: #065F46; font-size: 0.9rem; line-height: 1.5; font-style: italic; }

        @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        /* --- 5. Submit Button --- */
        .btn-submit {
            width: 100%;
            background-color: var(--primary-green);
            color: white;
            border: none;
            padding: 16px;
            border-radius: 50px;
            font-size: 1.05rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
        }
        .btn-submit:hover { background-color: var(--primary-green-hover); box-shadow: 0 8px 25px rgba(16, 185, 129, 0.25); transform: translateY(-2px); }

        /* --- Responsive --- */
        @@media (max-width: 768px) {
            .review-card { padding: 30px 20px; }
            .service-summary { flex-direction: column; text-align: center; }
        }
        /* --- THIẾT KẾ NAVBAR CHUẨN NHƯ ẢNH --- */
.navbar {
