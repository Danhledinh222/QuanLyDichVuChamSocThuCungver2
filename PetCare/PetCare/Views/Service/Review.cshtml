    <!-- MAIN CONTENT: REVIEW PAGE -->
    <main class="main-content">
        <div class="container">
            
            <div class="review-wrapper">
                <div class="review-header">
                    <h2>Đánh giá dịch vụ</h2>
                    <p>Cảm ơn bạn đã lựa chọn PetCare. Ý kiến của bạn giúp chúng tôi phục vụ tốt hơn.</p>
                </div>

                <div class="review-card">
                    <!-- 1. Service Summary -->
                    <div class="service-summary">
                        <img src="https://images.unsplash.com/photo-1543466835-00a7907e9de1?auto=format&fit=crop&q=80&w=200" alt="Pet Avatar" class="ss-avatar">
                        <div class="ss-info">
                            <h4>Milo</h4>
                            <p><strong>Dịch vụ:</strong> Cắt tỉa lông cao cấp & Tắm Spa</p>
                            <p><strong>Ngày:</strong> 15/05/2026 • <strong>Nhân viên:</strong> Sarah M.</p>
                        </div>
                    </div>

                    <form id="reviewForm" onsubmit="event.preventDefault(); submitReview();">
                        <!-- 2. Rating Section -->
                        <div class="rating-section">
                            <h5>Bạn đánh giá trải nghiệm này thế nào?</h5>
                            <div class="stars-container" id="starRating">
                                <i class="far fa-star star-item" data-value="1"></i>
                                <i class="far fa-star star-item" data-value="2"></i>
                                <i class="far fa-star star-item" data-value="3"></i>
                                <i class="far fa-star star-item" data-value="4"></i>
                                <i class="far fa-star star-item" data-value="5"></i>
                            </div>
                        </div>

                        <!-- 3. Tags -->
                        <label class="form-label">Điều gì làm bạn hài lòng nhất?</label>
                        <div class="tags-container">
                            <button type="button" class="review-tag">Nhân viên thân thiện</button>
                            <button type="button" class="review-tag">Kỹ năng chuyên nghiệp</button>
                            <button type="button" class="review-tag">Không gian sạch sẽ</button>
                            <button type="button" class="review-tag">Nhanh chóng</button>
                            <button type="button" class="review-tag">Thú cưng vui vẻ</button>
                        </div>

                        <!-- Textarea -->
                        <label class="form-label">Chia sẻ chi tiết trải nghiệm của bạn</label>
                        <textarea class="form-control-custom" id="reviewText" placeholder="PetCare đã chăm sóc bé Milo như thế nào? (Không bắt buộc)"></textarea>

                        <!-- 4. Store Reply Preview -->
                        <div class="reply-preview" id="storeReply">
                            <h6><i class="fas fa-reply"></i> Phản hồi từ PetCare</h6>
                            <p>"Cảm ơn bạn đã dành thời gian đánh giá. Chúng tôi rất vui vì Milo đã có một trải nghiệm tuyệt vời tại cửa hàng. Rất mong được gặp lại bé trong lần tới!"</p>
                        </div>

                        <!-- 5. Submit Button -->
                        <button type="submit" class="btn-submit" id="submitBtn" disabled style="opacity: 0.6; cursor: not-allowed;">
                            <i class="fas fa-paper-plane"></i> Gửi đánh giá
                        </button>
                    </form>
                </div>
            </div>

        </div>
